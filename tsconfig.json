{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist/",
    //Подсвечивает где не указан тип
    "noImplicitAny": true,
    "module": "ESNext",
    //в какую спецификацию компилируем
    "target": "es5",
    "jsx": "react-jsx",
    //позволяет обрабатывать не только TS но и JS
    "allowJs": true,
    "moduleResolution": "node",
    // esModuleInterop позволяет работать с пакетами, которые используют common js как с обычными пакетами
    //с помощью import (require() module.export) = common js
    "allowSyntheticDefaultImports": true,
    // import * as React from 'react' === import React from 'react'
    "esModuleInterop": true
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}